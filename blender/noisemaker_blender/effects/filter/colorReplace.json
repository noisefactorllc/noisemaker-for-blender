{
  "name": "Color Replace",
  "namespace": "filter",
  "func": "colorReplace",
  "tags": [
    "color",
    "util"
  ],
  "paramAliases": {},
  "defaultProgram": "search filter, synth\n\nnoise(ridges: true, colorMode: mono)\n.colorReplace(targetColor: #000000, replaceColor: #ff0000, sensitivity: 0.4, smoothing: 0.2)\n.write(o0)",
  "globals": {
    "targetColor": {
      "type": "color",
      "default": [
        0,
        0,
        0
      ],
      "uniform": "targetColor"
    },
    "replaceColor": {
      "type": "color",
      "default": [
        1,
        1,
        1
      ],
      "uniform": "replaceColor"
    },
    "sensitivity": {
      "type": "float",
      "default": 0.3,
      "uniform": "sensitivity",
      "min": 0,
      "max": 1
    },
    "smoothing": {
      "type": "float",
      "default": 0.1,
      "uniform": "smoothing",
      "min": 0,
      "max": 1
    },
    "colorMix": {
      "type": "float",
      "default": 1,
      "uniform": "colorMix",
      "min": 0,
      "max": 1
    },
    "replaceAlpha": {
      "type": "float",
      "default": 1,
      "uniform": "replaceAlpha",
      "min": 0,
      "max": 1
    },
    "keepAlpha": {
      "type": "float",
      "default": 1,
      "uniform": "keepAlpha",
      "min": 0,
      "max": 1
    }
  },
  "passes": [
    {
      "name": "main",
      "program": "colorReplace",
      "inputs": {
        "inputTex": "inputTex"
      },
      "outputs": {
        "color": "outputTex"
      },
      "uniforms": {}
    }
  ],
  "textures": {}
}
